# Nette URLs: /pagina/ -> pagina.html
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([a-z0-9-]+)/?$ $1.html [L]

# 301-redirects vanaf oude WordPress-URLs
Redirect 301 /besturingskasten/ /besturingspanelen/
Redirect 301 /besturingskast-op-maat/ /besturingspanelen/
Redirect 301 /plc-besturingstechniek/ /plc-automatisering/
Redirect 301 /maak-kennis-met-onze-paneelbouwster-annemieke/ /paneelbouwster-annemieke/
Redirect 301 /nieuwe-samenwerking-tussen-van-dis-solutions-en-inpieq/ /samenwerking-inpieq/
Redirect 301 /ontmoet-rene-software-engineer-bij-van-dis-solutions/ /rene-software-engineer/
Redirect 301 /duurzame-partnerschap-van-dis-solutions-en-big-ass-battery/ /partnerschap-big-ass-battery/
Redirect 301 /bram-van-dis-het-gezicht-achter-van-dis-solutions/ /bram-van-dis/
Redirect 301 /brochure-downloaden/ /brochure/
Redirect 301 /recycling/ /over-ons/

# Security headers (op Vercel geregeld via vercel.json; op Apache hier)
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Caching: afbeeldingen en assets lang, HTML kort
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 10 minutes"
</IfModule>

# Compressie
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
